{
  "name": "afs-platform-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/generate-kernel-routes.js && vite",
    "build": "node ../scripts/generate-kernel-routes.js && tsc -b && vite build",
    "build:static": "node ../scripts/generate-kernel-routes.js && tsc -b && vite build --config vite.config.static.ts",
