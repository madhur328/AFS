# Discord bot token — https://discord.com/developers/applications
# Bot tab: enable Message Content Intent
# Installation: scopes bot + applications.commands, permissions View Channels + Read Message History
DISCORD_BOT_TOKEN=

# Optional overrides (defaults in data/discord-server.json)
# DISCORD_GUILD_ID=1498477844945436732
# DISCORD_SYNC_CHANNEL_NAMES=journal

# --- npm run dev launches ---
# [journal]  scripts/discord-bot.js  — REQUIRED to sync #journal into AFS (no ngrok)
# [slash]    projects/discord-bot-setup — optional /test slash commands
# [ngrok]    tunnel for slash app only (not needed for journal sync)

# Path to ngrok.exe (auto-detected in Downloads/Compressed if unset)
# NGROK_PATH=C:\Users\Madhur\Downloads\Compressed\ngrok.exe

# Slash interactions app port (default 3001)
# DISCORD_SLASH_PORT=3001

# Set to 0 to skip slash app + ngrok during dev
# DISCORD_ENABLE_SLASH=1

# Canonical data directory — afs.db, journal images, lore corpus (default: <project>/data)
# AFS_DATA_DIR=G:\AFS\data

# Grok genesis thread (default: data/grok-37560952, fallback D:\wallpapers\afs-platform\...)
# GROK_DATA_DIR=G:\AFS\data\grok-37560952

# Motion artifacts + ENTHEA (defaults: <project>/videos/afs, <project>/enthea-rs.exe)
# AFS_VIDEOS_DIR=D:\wallpapers\afs-platform\videos\afs
# ENTHEA_EXE=D:\wallpapers\afs-platform\enthea-rs.exe